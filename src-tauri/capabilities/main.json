{
  "identifier": "main-capability",
  "description": "Main capability for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:default",
    "fs:default",
    "fs:allow-read",
    "mcp-bridge:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$PICTURE/**" },
        { "path": "$APPDATA/**" },
        { "path": "$HOME/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" }
      ]
    }
  ]
}
