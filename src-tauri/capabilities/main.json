{
  "identifier": "main-capability",
  "description": "Main capability for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:default",
    "fs:default",
    "fs:allow-read",
    "mcp-bridge:default",
    {
      "identifier": "fs:scope",
      "allow": [
        "$PICTURE/**",
        "$APPDATA/**",
        "$HOME/**"
      ]
    }
  ]
}
