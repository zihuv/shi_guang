{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shiguang",
  "version": "0.2.1",
  "identifier": "com.zihuv.shiguang",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "拾光",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$PICTURE/**",
          "$APPDATA/**",
          "$HOME/**",
          "$DOWNLOAD/**",
          "$DOCUMENT/**",
          "$DESKTOP/**",
          "$PICTURE/**/.shiguang/thumbnails/**/*",
          "$APPDATA/**/.shiguang/thumbnails/**/*",
          "$HOME/**/.shiguang/thumbnails/**/*",
          "$DOWNLOAD/**/.shiguang/thumbnails/**/*",
          "$DOCUMENT/**/.shiguang/thumbnails/**/*",
          "$DESKTOP/**/.shiguang/thumbnails/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "resources": {
      "target/release/DirectML.dll": "DirectML.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/64x64.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
