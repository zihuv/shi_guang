{
  "name": "shiguang",
  "version": "0.5.4",
  "private": true,
  "type": "module",
  "main": "out/main/main.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "renderer:dev": "vite --host 127.0.0.1",
    "electron:dev": "electron-vite dev",
    "build": "tsc && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky",
    "precommit": "lint-staged",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "lint": "oxlint --react-plugin src electron extensions/shiguang-collector electron.vite.config.ts drizzle.config.ts vite.config.ts tailwind.config.js postcss.config.js",
    "lint:fix": "oxlint --react-plugin --fix src electron extensions/shiguang-collector electron.vite.config.ts drizzle.config.ts vite.config.ts tailwind.config.js postcss.config.js",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "review:claude": "bash scripts/claude-review.sh",
    "knip": "knip --include files,dependencies,unlisted,binaries,unresolved",
    "test": "vitest run",
    "fmt": "oxfmt src electron extensions/shiguang-collector index.html electron.vite.config.ts drizzle.config.ts vite.config.ts tailwind.config.js postcss.config.js",
    "fmt:check": "oxfmt --check src electron extensions/shiguang-collector index.html electron.vite.config.ts drizzle.config.ts vite.config.ts tailwind.config.js postcss.config.js",
    "preview": "vite preview",
    "package:size-report": "node scripts/report-package-size.cjs release",
    "release": "node scripts/release.cjs",
    "docs:dev": "cd website && rspress dev",
    "docs:build": "cd website && rspress build",
    "docs:preview": "cd website && rspress preview"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@huggingface/tokenizers": "^0.1.3",
    "@napi-rs/canvas": "^0.1.99",
    "@webtoon/psd": "^0.4.0",
    "better-sqlite3": "^12.5.0",
    "chokidar": "^4.0.3",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "fastify": "^5.6.2",
    "match-sorter": "^8.3.0",
    "onnxruntime-node": "^1.24.3",
    "pdfjs-dist": "^5.6.205",
    "pinyin-match": "^1.2.10",
    "sharp": "^0.34.5",
    "unpdf": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.10",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@rspress/core": "^2.0.9",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "6.0.0-beta.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.6.2",
    "lint-staged": "^16.4.0",
    "lucide-react": "^1.7.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.5",
    "zustand": "^5.0.12"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs}": [
      "oxfmt",
      "oxlint --react-plugin --fix --no-error-on-unmatched-pattern"
    ],
    "*.html": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.zihuv.shiguang",
    "productName": "拾光",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "artifactName": "${name}_${version}_${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "zihuv",
        "repo": "shiguang"
      }
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "files": [
      "out/**",
      "drizzle/**",
      "src/assets/app-icon.png",
      "package.json",
      "!**/node_modules/better-sqlite3/deps/**",
      "!**/node_modules/better-sqlite3/src/**",
      "!**/node_modules/better-sqlite3/binding.gyp",
      "!**/node_modules/onnxruntime-node/lib/**",
      "!**/node_modules/onnxruntime-node/script/**",
      "!**/node_modules/pdfjs-dist/build/**",
      "!**/node_modules/pdfjs-dist/types/**",
      "!**/node_modules/pdfjs-dist/web/**",
      "!**/node_modules/pdfjs-dist/legacy/web/**",
      "!**/node_modules/pdfjs-dist/**/*.map"
    ],
    "extraResources": [
      {
        "from": "assets/app-icon.png",
        "to": "assets/app-icon.png"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*",
      "**/node_modules/@napi-rs/**/*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/onnxruntime-node/**/*"
    ],
    "afterPack": "scripts/after-pack-prune.cjs",
    "electronLanguages": [
      "en",
      "en-US",
      "zh_CN",
      "zh-CN"
    ],
    "npmRebuild": true,
    "nativeRebuilder": "sequential",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "zihuv <zihuv@users.noreply.github.com>"
    }
  }
}
