{
  "name": "shiguang",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "oxlint --react-plugin src vite.config.ts tailwind.config.js postcss.config.js",
    "lint:fix": "oxlint --react-plugin --fix src vite.config.ts tailwind.config.js postcss.config.js",
    "fmt": "oxfmt src index.html vite.config.ts tailwind.config.js postcss.config.js",
    "fmt:check": "oxfmt --check src index.html vite.config.ts tailwind.config.js postcss.config.js",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:mem": "tauri dev --features memory-diagnostics",
    "tauri:dev:heap": "tauri dev --features memory-heap",
    "release": "node scripts/release.cjs",
    "docs:dev": "cd website && rspress dev",
    "docs:build": "cd website && rspress build",
    "docs:preview": "cd website && rspress preview"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.10",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "postcss": "^8.5.8",
    "rspress": "^1.47.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  }
}
