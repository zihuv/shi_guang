{
  "name": "shiguang",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "main": "out/main/main.cjs",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "renderer:dev": "vite --host 127.0.0.1",
    "electron:dev": "electron-vite dev",
    "build": "tsc && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "lint": "oxlint --react-plugin src electron electron.vite.config.ts vite.config.ts tailwind.config.js postcss.config.js",
    "lint:fix": "oxlint --react-plugin --fix src electron electron.vite.config.ts vite.config.ts tailwind.config.js postcss.config.js",
    "test": "vitest run",
    "fmt": "oxfmt src electron index.html electron.vite.config.ts vite.config.ts tailwind.config.js postcss.config.js",
    "fmt:check": "oxfmt --check src electron index.html electron.vite.config.ts vite.config.ts tailwind.config.js postcss.config.js",
    "preview": "vite preview",
    "release": "node scripts/release.cjs",
    "docs:dev": "cd website && rspress dev",
    "docs:build": "cd website && rspress build",
    "docs:preview": "cd website && rspress preview"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.10",
    "@fastify/cors": "^11.1.0",
    "@huggingface/tokenizers": "^0.1.3",
    "@napi-rs/canvas": "^0.1.99",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.23",
    "@webtoon/psd": "^0.4.0",
    "better-sqlite3": "^12.5.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "fastify": "^5.6.2",
    "file-type": "^21.1.1",
    "fs-extra": "^11.3.2",
    "lucide-react": "^1.7.0",
    "onnxruntime-node": "^1.24.3",
    "p-queue": "^9.0.1",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "unpdf": "^1.6.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "6.0.0-beta.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "postcss": "^8.5.8",
    "rspress": "^0.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.zihuv.shiguang",
    "productName": "拾光",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "artifactName": "${name}_${version}_${arch}.${ext}",
    "files": [
      "out/**",
      "src/assets/app-icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/app-icon.png",
        "to": "assets/app-icon.png"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*",
      "**/node_modules/@napi-rs/**/*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/onnxruntime-node/**/*"
    ],
    "npmRebuild": true,
    "nativeRebuilder": "sequential",
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "zihuv <zihuv@users.noreply.github.com>"
    }
  }
}
